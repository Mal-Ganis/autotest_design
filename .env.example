# AutoTestDesign — 可选 LLM（不要提交真实密钥）
# 复制为 .env 并填写。仓库 .gitignore 已忽略 .env

# ---------- 方式 A：OpenAI 官方或任意 OpenAI 兼容网关 ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------- 方式 B：DeepSeek（与 OpenAI 二选一；若同时填，优先使用 OPENAI_*）----------
DEEPSEEK_API_KEY=
# 官方一般为 https://api.deepseek.com/v1
DEEPSEEK_API_URL=https://api.deepseek.com/v1
# 官方常见：deepseek-v4-pro、deepseek-v4-flash
# 若写成 OpenRouter 风格 deepseek/deepseek-v4-pro，程序会自动去掉前缀
MODEL=deepseek-v4-pro
